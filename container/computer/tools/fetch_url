#!/bin/sh
# fetch_url <url> — fetch a page and return its main content as clean markdown (token-efficient).
# For static/article pages; for JS-heavy sites or interaction, use `agent-browser open <url>`.
# On failure it surfaces the underlying error (never swallows it) so the peer can see what went wrong.
set -eu

url="${1:-}"

if [ -z "$url" ]; then
  echo "usage: fetch_url <url>" >&2
  exit 1
fi

# Capture stderr separately so a real error (network, rate-limit, parse) can be reported, not hidden.
out=$(trafilatura --markdown -u "$url" 2>/tmp/fetch_err) || true

if [ -n "$out" ]; then
  printf '%s\n' "$out"
  exit 0
fi

echo "fetch_url: no content extracted from $url" >&2
if [ -s /tmp/fetch_err ]; then
  echo "details:" >&2
  tail -n 8 /tmp/fetch_err >&2
fi
exit 1
