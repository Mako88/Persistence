#!/bin/sh
# Git credential helper for peers: supplies the GitHub token from a read-only mount, so the secret
# lives only in a mounted file (rotate = replace the file) and is never baked into the image or stored
# in git config / .git-credentials. Git invokes this with "get" | "store" | "erase"; we only answer
# "get", reading the token mounted at /run/secrets/github-token. No token => no output => git falls back.
[ "$1" = "get" ] || exit 0
TOKEN_FILE=/run/secrets/github-token
[ -f "$TOKEN_FILE" ] || exit 0
printf 'username=x-access-token\n'
printf 'password=%s\n' "$(cat "$TOKEN_FILE")"
